{
  "custom_fonts": [
    "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Inter:wght@400;500;700&display=swap"
  ],
  "variables": {
    "light": {
      "--font-sans": "'Inter', sans-serif",
      "--font-mono": "'JetBrains Mono', monospace",
      "--background": "210 40% 98%",
      "--foreground": "240 10% 10%",
      "--card": "0 0% 100% / 0.7",
      "--card-foreground": "240 10% 10%",
      "--primary": "188 100% 45%",
      "--primary-foreground": "0 0% 100%",
      "--border": "188 100% 85% / 0.5",
      "--radius": "0.75rem"
    },
    "dark": {
      "--font-sans": "'Inter', sans-serif",
      "--font-mono": "'JetBrains Mono', monospace",
      "--background": "225 30% 6%",
      "--foreground": "240 20% 96%",
      "--card": "225 30% 10% / 0.6",
      "--card-foreground": "240 20% 96%",
      "--primary": "188 100% 50%",
      "--primary-foreground": "225 30% 6%",
      "--border": "188 100% 30% / 0.5",
      "--radius": "0.75rem"
    }
  }
}