# ============================================
#  NexusAI .gitignore
# ============================================

# ---- Environment secrets ----
.env
.env.*
!.env.example

# ---- Python cache & bytecode ----
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# ---- Virtual environments ----
.venv/
venv/
env/
.conda/

# ---- Data directories (local only) ----
data/
vector_store/
chromadb/
faiss_index/

# ---- Chainlit local database & state ----
chainlit.db
chainlit.db-shm
chainlit.db-wal
.chainlit/.sessions/

# ---- User-uploaded elements (served locally only) ----
public/elements/
public/uploads/

# ---- Editor & IDE ----
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# Local AI Agent Data
.agents/

# ---- OS Files ----
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ---- Logs ----
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Node (if any frontend tooling is added) ----
node_modules/
.npm

# ---- Jupyter Notebooks (data exploration) ----
.ipynb_checkpoints/

# ---- Test artifacts ----
.pytest_cache/
.coverage
htmlcov/
*.cover
*.xml

# ---- Model weights / large binary assets ----
*.bin
*.pt
*.ckpt
*.h5
*.pkl

# ---- Audio temp files ----
*.webm
*.wav
*.mp3
!public/**/*.mp3

# ---- Temporary / scratch files ----
tmp/
temp/
.agents
*.tmp
*.bak
*.swp
*~